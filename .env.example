# Supabase (from Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...   # SECRET

# Azure Speech (from portal.azure.com)
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxx            # SECRET
AZURE_SPEECH_REGION=westeurope

# HuggingFace (from huggingface.co → Settings → Access Tokens)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx    # SECRET

# Redis (from upstash.com or your local Redis)
REDIS_URL=redis://default:xxxxxxxx@us1-xxxx.upstash.io:6379   # SECRET

# App URLs (change when deployed)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=   # generate with: openssl rand -hex 32   (SECRET)